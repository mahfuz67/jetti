# --- Solana RPC (mainnet) ---
RPC_HTTP_URL=https://your-mainnet-rpc
RPC_WSS_URL=wss://your-mainnet-rpc

# --- Yellowstone gRPC (Geyser) ---
# Helius LaserStream / Triton Dragon's Mouth / QuickNode / Shyft / SolInfra
GRPC_URL=https://your-yellowstone-grpc:443
GRPC_TOKEN=

# --- Jito Block Engine ---
# Region host only (no scheme/path). One of:
# mainnet | amsterdam | dublin | frankfurt | london | ny | slc | singapore | tokyo
JITO_REGION=frankfurt

# --- Wallet (mainnet hot wallet, base58 secret key) ---
# Generate with: solana-keygen new -o keys/hot.json  then export base58, OR paste a base58 secret.
WALLET_SECRET=

# --- AI agent ---
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

# --- Tuning ---
# Submission window: minimum slots that must remain in the current leader's
# 4-slot turn to submit (higher = stricter, opens fewer slots). 3 opens the
# first two slots of each turn (~50%); 4 opens only the first slot (~25%).
LEADER_WINDOW_SLOTS=3
# Hard ceiling on tip the agent may set (lamports), as a cost guardrail.
MAX_TIP_LAMPORTS=100000
# Self-transfer amount used for no-op demo bundles (lamports).
PROBE_TRANSFER_LAMPORTS=1000
LOG_LEVEL=info
